# Clave de API de OpenAI (obligatoria)
OPENAI_API_KEY=sk-...

# Orígenes permitidos por CORS, separados por coma.
# Usá "*" solo para pruebas locales; en producción poné el dominio real
# donde vas a alojar agente_fvh.html (ej: https://tuusuario.github.io)
ALLOWED_ORIGINS=*

# Modelos (opcional, valores por defecto ya son estos)
LLM_MODEL=gpt-4.1-mini
EMBEDDINGS_MODEL=text-embedding-3-small

# Carpetas (opcional)
KB_DIR=knowledge_base
INDEX_DIR=faiss_index
